import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
from matplotlib import rcParams
import seaborn as sns
import warnings

#Data load
df_titanic = sns.load_dataset('titanic')

#Understanding data
print(df_titanic.head())
print(df_titanic.info())
print(df_titanic.describe())

#Value counts
print(df_titanic['survived'].value_counts())
print(df_titanic['sex'].value_counts())
print(df_titanic['age'].value_counts())
print(df_titanic['fare'].value_counts())
print(df_titanic['class'].value_counts())
print(df_titanic['who'].value_counts())


##########Visualization##########
#Distribution

#Age별 count histogram
sns.histplot(data=df_titanic, x='age')
#plt.show()

#class별 count
sns.catplot(x="class", kind="count", data=df_titanic)
#plt.show()


#class별 승객 수를 세면서, who 기준으로 색을 나누는 그래프
sns.catplot(x="class", hue='who', kind='count', data=df_titanic) #hue: 2개의 변수 관계를 보기위한 방법

#살아있는 사람들의 수를 세면서, class기준으로 색을 나누는 그래프
sns.catplot(x='survived', hue='class', kind='count', data=df_titanic)

#class별로 승객의 수를 세면서,survived에 따라 색을 나눠 stack형태로 보여줌.
sns.histplot(x='class', hue='survived', multiple= 'stack', shrink=.5, data=df_titanic)  #shrink: 막대의 너비를 줄여줌,

#bar graph: class별 나이의 평균값을 보여줌
sns.catplot(x="class", y='age',hue='sex', kind='bar', data=df_titanic)

#proportion of survivors and dead
fig, axes = plt.subplots(ncols=2)  #ncols: column의 개수  , 그래프 한번에 두개를 만드는 것
df_titanic["survived"].value_counts().plot(kind="bar", ax = axes[0])  #ax: 그래프 순서
df_titanic["survived"].value_counts().plot(kind="pie", autopct='%1.1f%%', ax=axes[1]) #살아있는 사람들의

plt.show()
